{
  "name": "tool-ui",
  "version": "0.2.0",
  "private": true,
  "description": "Open source component library for tool call widgets",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --experimental-build-mode=compile",
    "start": "next start",
    "prepare": "tsx scripts/install-git-hooks.ts",
    "component:new": "tsx scripts/new-tool-ui-component.ts",
    "changelog:generate": "tsx scripts/generate-changelog.ts",
    "changelog:generate:manual": "tsx scripts/generate-changelog.ts",
    "changelog:generate:from-tag": "tsx scripts/generate-changelog.ts --from-tag",
    "changelog:check": "tsx scripts/check-changelog.ts",
    "registry:build": "tsx scripts/build-tool-ui-registry.ts",
    "registry:check": "tsx scripts/registry-check.ts",
    "weather:compile": "tsx scripts/compile-weather-runtime.ts",
    "weather:watch": "tsx scripts/compile-weather-runtime.ts --watch",
    "weather:check": "tsx scripts/compile-weather-runtime.ts --check",
    "hooks:pre-commit": "tsx scripts/precommit-registry-sync.ts",
    "hooks:pre-push": "pnpm lint && pnpm lint:format && pnpm registry:check",
    "lint:oxlint": "oxlint",
    "lint:eslint": "eslint .",
    "lint": "pnpm lint:oxlint && pnpm lint:eslint",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "lint:format": "oxfmt --check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check": "run-p typecheck lint:oxlint lint:eslint lint:format",
    "verify:ci": "run-p typecheck lint:oxlint lint:eslint lint:format test changelog:check registry:check weather:check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile",
    "ci:publish": "pnpm --filter './packages/*' build && changeset publish"
  },
  "dependencies": {
