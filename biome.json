{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "includes": [
      "apps/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}",
      "packages/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}",
      "scripts/**/*.{ts,js,mjs}",
      "*.{json,jsonc}",
      "!**/dist",
      "!**/node_modules",
      "!**/.next",
      "!**/out",
      "!**/coverage",
      "!**/.turbo",
      "!**/next-env.d.ts",
      "!apps/www/public/r",
      "!apps/www/components/tool-ui/weather-widget/generated",
      "!apps/www/lib/weather-authoring/weather-widget/effects/*.generated.js",
      "!apps/www/lib/weather-authoring/weather-widget/effects",
      "!apps/www/lib/weather-authoring/**/*.generated.ts",
      "!apps/www/app/sandbox",
      "!apps/www/app/staging",
      "!apps/www/lib/staging",
      "!packages/agent/dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "css": {
    "formatter": { "enabled": false },
    "linter": { "enabled": false }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noShadowRestrictedNames": "off",
        "noControlCharactersInRegex": "off",
        "noDocumentCookie": "off",
        "noAssignInExpressions": "off",
        "useIterableCallbackReturn": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "error"
      },
      "complexity": {
        "noBannedTypes": "off"
      },
      "style": {
        "useImportType": "off",
        "useNodejsImportProtocol": "off",
        "noNonNullAssertion": "off"
      },
      "a11y": {
        "noAutofocus": "off",
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "useMediaCaption": "off",
        "useIframeTitle": "off",
        "useValidAriaRole": "off",
        "useHeadingContent": "off",
        "useAnchorContent": "off",
        "noSvgWithoutTitle": "off",
        "useAriaPropsForRole": "off",
        "useSemanticElements": "off",
        "useFocusableInteractive": "off",
        "useAriaPropsSupportedByRole": "off",
        "useButtonType": "off"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "functions": ["clsx", "cn", "cva", "tw", "twMerge", "twJoin", "tv"]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "plugins": []
}
